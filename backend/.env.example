# Exchange selection
# Options: weex | binance | bybit | okx  (default: weex)
EXCHANGE=weex

# WEEX credentials (optional — only needed for private endpoints)
WEEX_API_KEY=
WEEX_SECRET=

# Binance credentials (optional)
BINANCE_API_KEY=
BINANCE_SECRET=

# Bybit credentials (optional)
BYBIT_API_KEY=
BYBIT_SECRET=

# OKX credentials (optional)
OKX_API_KEY=
OKX_SECRET=
OKX_PASSPHRASE=

# ML model
ML_CONFIDENCE_THRESHOLD=65

# Finora AI (Anthropic)
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# App settings
LOG_LEVEL=INFO
DEFAULT_TIMEFRAME=1h
