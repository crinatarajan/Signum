# ── WEEX Exchange (primary) ────────────────────────────────────────────────
# Create keys at: https://www.weex.com → Account → API Management
# Read-only keys are sufficient for signal generation.
WEEX_API_KEY=your_weex_api_key_here
WEEX_SECRET=your_weex_secret_here

# ── Anthropic (Finora AI analysis) ────────────────────────────────────────
# Get your key at: https://console.anthropic.com
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# ── App settings ──────────────────────────────────────────────────────────
LOG_LEVEL=INFO
DEFAULT_EXCHANGE=weex
DEFAULT_TIMEFRAME=1h
